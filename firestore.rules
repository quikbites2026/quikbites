rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Settings — readable by all, writable only by authenticated users
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories — readable by all, writable only by authenticated users
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Menu items — readable by all, writable only by authenticated users
    match /menuItems/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders — customers can create, only authenticated users can read/update
    match /orders/{doc} {
      allow create: if true;
      allow read, update: if request.auth != null || request.auth == null && resource.data.keys().hasAny(['id']);
      allow read: if true; // Allow customers to track their own order
    }
  }
}

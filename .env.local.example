# Firebase Configuration
# Get these from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Admin Credentials (set these in Firebase Auth)
# Admin email: admin@quikbites.com (create in Firebase Authentication)
# Kitchen email: kitchen@quikbites.com (create in Firebase Authentication)

# M-SELEN API (add when available)
NEXT_PUBLIC_MSELEN_MERCHANT_ID=your_mselen_merchant_id
MSELEN_API_KEY=your_mselen_api_key
MSELEN_API_URL=https://api.mselen.com
